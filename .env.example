# ── AI Job Hunter — Environment Variables ──
# Copy this file to .env and fill in your API keys.

# Required: OpenAI API key (for AI matching & material generation)
OPENAI_API_KEY=sk-your-key-here

# Optional: SerpAPI key (for Google Jobs scraping — 100 free searches/month)
# Get one at: https://serpapi.com
SERPAPI_KEY=

# Optional: Adzuna API (structured job data — free tier)
# Register at: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: USAJobs API (government positions — free)
# Register at: https://developer.usajobs.gov
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional: Email settings (for auto-apply via email)
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional: Model configuration
MATCHER_MODEL=gpt-4o-mini
GENERATOR_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
